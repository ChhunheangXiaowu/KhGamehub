{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(.*iPhone|Android|Mobile|iPad|iPod.*)"
        }
      ],
      "destination": "/mobile-blocked.html",
      "permanent": false
    }
  ]
}